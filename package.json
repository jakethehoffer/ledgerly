{
  "name": "ledgerly",
  "version": "0.9.1",
  "description": "Stripe-to-double-entry mapping engine for indie SaaS",
  "keywords": [
    "stripe",
    "accounting",
    "double-entry",
    "bookkeeping",
    "quickbooks",
    "xero",
    "webhooks",
    "fintech",
    "journal-entries",
    "revenue-recognition"
  ],
  "homepage": "https://github.com/jakethehoffer/ledgerly#readme",
  "bugs": {
    "url": "https://github.com/jakethehoffer/ledgerly/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jakethehoffer/ledgerly.git"
  },
  "license": "Apache-2.0",
  "author": "Jake <14jakehoffman@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ledgerly-server": "dist/server/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "e2e:fixtures": "vitest run test/engine.spec.ts test/exporters",
    "build": "tsc --project tsconfig.build.json",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "demo": "pnpm build && node examples/quickstart.mjs",
    "start": "node dist/server/cli.js"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "stripe": "^16"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "dotenv": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.41",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "express": "^4.22.2",
    "prettier": "^3.8.3",
    "stripe": "^16",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
