{
  "name": "ledgerly",
  "version": "0.0.1",
  "description": "Stripe-to-double-entry mapping engine for indie SaaS",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "e2e:fixtures": "vitest run test/engine.spec.ts test/exporters"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "stripe": "^16.12.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
