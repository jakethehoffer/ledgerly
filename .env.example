# ============================================================================
# ledgerly environment configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env`, fill in the values, and `pnpm start` will load them
# automatically. `.env` is gitignored — never commit secrets.
# ============================================================================

# ---- Server -----------------------------------------------------------------

# Port the receiver listens on. Default 3000.
PORT=3000

# Log level: debug | info | warn | error. Default info.
LEDGERLY_LOG_LEVEL=info

# Metrics namespace prefix (all metrics get prefixed `<namespace>_`). Default ledgerly.
LEDGERLY_METRICS_NAMESPACE=ledgerly

# ---- Persistence ------------------------------------------------------------

# SQLite file path. If unset, falls back to in-memory storage (data lost on restart).
LEDGERLY_DB_PATH=./ledger.db

# ---- Scheduler --------------------------------------------------------------

# Enable the background scheduler that posts due scheduled_entries via the
# configured dispatcher. Without this, future-dated recognition entries
# (annual subs) sit pending forever.
LEDGERLY_SCHEDULER_ENABLED=true

# Polling interval in milliseconds. Default 60000 (60s).
LEDGERLY_SCHEDULER_INTERVAL_MS=60000

# Max retry attempts before an entry is dead-lettered (status='failed'). Default 10.
LEDGERLY_SCHEDULER_MAX_ATTEMPTS=10

# ---- Stripe (webhook receiver) ---------------------------------------------

# Stripe API secret key — used to expand balance_transaction et al. before mapEvent.
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret — used to verify POSTs to /webhook.
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- OAuth state CSRF -------------------------------------------------------

# Secret for HMAC-signing OAuth state tokens. Generate with:
#   openssl rand -base64 48
# Required if you use the OAuth flow for either QBO or Xero. Min 32 chars.
LEDGERLY_OAUTH_STATE_SECRET=

# ---- Admin endpoints --------------------------------------------------------

# Bearer token gating the /admin/* operational endpoints (list entries,
# inspect scheduled rows, manually retry dead-lettered dispatches). If unset,
# /admin/* routes return 404 — they are not even mounted. Generate with:
#   openssl rand -base64 48
# Min 32 chars when set.
LEDGERLY_ADMIN_TOKEN=

# ---- QuickBooks Online ------------------------------------------------------

# OAuth path (preferred). Get from https://developer.intuit.com/app/developer/dashboard
# → your app → Keys and credentials → Development.
LEDGERLY_QBO_CLIENT_ID=
LEDGERLY_QBO_CLIENT_SECRET=

# Redirect URI must match EXACTLY what's registered in the Intuit dashboard.
# For local dev: http://localhost:3000/oauth/qbo/callback
LEDGERLY_QBO_REDIRECT_URI=http://localhost:3000/oauth/qbo/callback

# Sandbox base URL (for development keys against an Intuit sandbox company).
# Comment out / remove for production keys.
LEDGERLY_QBO_API_BASE=https://sandbox-quickbooks.api.intuit.com

# Account map: maps ledgerly's 12 account codes to your QBO account IDs.
# Get account IDs from QBO via API or by inspecting account URLs in the QBO UI.
LEDGERLY_QBO_ACCOUNT_MAP_JSON={"1000":{"qboId":"","name":"Operating Bank"},"1010":{"qboId":"","name":"Stripe Clearing"},"1100":{"qboId":"","name":"Accounts Receivable"},"1200":{"qboId":"","name":"Disputes Receivable"},"2000":{"qboId":"","name":"Sales Tax Payable"},"2100":{"qboId":"","name":"Deferred Revenue"},"4000":{"qboId":"","name":"Subscription Revenue"},"4100":{"qboId":"","name":"Application Fee Revenue"},"4900":{"qboId":"","name":"Refunds Issued"},"6000":{"qboId":"","name":"Stripe Processing Fees"},"6100":{"qboId":"","name":"Payment Disputes"},"7000":{"qboId":"","name":"FX Gain/Loss"}}

# ---- Xero -------------------------------------------------------------------

# OAuth path (preferred). Get from https://developer.xero.com/app/manage
# → your app → Configuration.
LEDGERLY_XERO_CLIENT_ID=
LEDGERLY_XERO_CLIENT_SECRET=

# Redirect URI must match the Xero app config exactly.
LEDGERLY_XERO_REDIRECT_URI=http://localhost:3000/oauth/xero/callback

# Account map: maps ledgerly's 12 account codes to Xero account codes.
LEDGERLY_XERO_ACCOUNT_MAP_JSON={"1000":{"accountCode":""},"1010":{"accountCode":""},"1100":{"accountCode":""},"1200":{"accountCode":""},"2000":{"accountCode":""},"2100":{"accountCode":""},"4000":{"accountCode":""},"4100":{"accountCode":""},"4900":{"accountCode":""},"6000":{"accountCode":""},"6100":{"accountCode":""},"7000":{"accountCode":""}}

# Status to post Xero ManualJournal entries as: DRAFT (default — user reviews) or POSTED.
LEDGERLY_XERO_STATUS=DRAFT

# ---- Static-token fallback (legacy / non-OAuth path) -----------------------

# If you don't want to use the OAuth flow, you can paste tokens directly here.
# The OAuth env vars above win when both are configured.
# LEDGERLY_QBO_ACCESS_TOKEN=
# LEDGERLY_QBO_REALM_ID=
# LEDGERLY_XERO_ACCESS_TOKEN=
# LEDGERLY_XERO_TENANT_ID=
